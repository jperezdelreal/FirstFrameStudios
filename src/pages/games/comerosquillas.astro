---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="ComeRosquillas — FirstFrame Studios">
  <div class="container mx-auto px-4 py-8">
    <div class="mb-6">
      <a href="/FirstFrameStudios/" class="text-primary hover:text-primary-dark transition-colors">← Back to Games</a>
    </div>
    
    <div class="bg-gray-800 rounded-lg p-6 mb-6">
      <h1 class="text-4xl font-bold mb-4">🍩 ComeRosquillas</h1>
      <p class="text-gray-300 mb-2">A Simpsons-themed Pac-Man arcade clone featuring Homer's donut quest</p>
      <p class="text-sm text-gray-400">Stack: HTML + JavaScript + Canvas</p>
      <div class="mt-4">
        <a href="https://github.com/jperezdelreal/ComeRosquillas" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>
    
    <div class="bg-gray-800 rounded-lg p-2">
      <iframe 
        src="https://jperezdelreal.github.io/ComeRosquillas/"
        class="w-full rounded"
        style="height: 700px; border: none;"
        title="ComeRosquillas Game"
        sandbox="allow-scripts allow-same-origin"
        loading="lazy"
      ></iframe>
    </div>
    
    <div class="mt-6 bg-gray-800 rounded-lg p-4 text-sm text-gray-400">
      <p class="font-semibold text-gray-300 mb-2">About ComeRosquillas:</p>
      <p class="mb-2">Navigate Homer Simpson through Springfield's maze, eating donuts while avoiding ghosts with distinct AI personalities. Features procedural audio generated via Web Audio API.</p>
      <p class="font-semibold text-gray-300 mb-1 mt-3">Controls:</p>
      <ul class="list-disc list-inside space-y-1">
        <li>Arrow Keys or WASD to move</li>
        <li>ENTER or SPACE to start</li>
        <li>P to pause</li>
        <li>M to toggle music</li>
      </ul>
    </div>
  </div>
</Layout>
