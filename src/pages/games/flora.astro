---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="FLORA — FirstFrame Studios">
  <div class="container mx-auto px-4 py-12">
    <div class="mb-8">
      <a href="/FirstFrameStudios/" class="inline-flex items-center gap-2 text-primary hover:text-primary-light transition-all duration-300 font-semibold">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Games
      </a>
    </div>
    
    <div class="glass-dark rounded-2xl p-8 mb-8">
      <div class="flex flex-col md:flex-row md:items-start gap-6">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-6xl">🌿</span>
            <div>
              <h1 class="text-4xl md:text-5xl font-black font-display">FLORA</h1>
              <p class="text-primary font-mono text-sm mt-1">Vite + TypeScript + PixiJS v8</p>
            </div>
          </div>
          <p class="text-gray-300 text-lg mb-4 leading-relaxed">
            Cozy gardening roguelite with procedural botanical art via L-systems. Every run creates unique living fractals 
            with watercolor gradients and seasonal palettes.
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="px-3 py-1 rounded-full glass text-sm font-medium">🌱 In Development</span>
            <span class="px-3 py-1 rounded-full glass text-sm font-medium">🎨 Procedural Art</span>
            <span class="px-3 py-1 rounded-full glass text-sm font-medium">🌸 L-Systems</span>
          </div>
        </div>
        <a 
          href="https://github.com/jperezdelreal/flora" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-emerald-500 to-green-600 hover:shadow-lg hover:shadow-emerald-500/50 transition-all duration-300 font-bold"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>
    
    <div class="glass-dark rounded-2xl p-3 mb-8">
      <div class="bg-gradient-to-br from-emerald-500/10 to-green-600/10 rounded-xl flex items-center justify-center relative overflow-hidden" style="min-height: 600px;">
        <div class="absolute inset-0 opacity-20">
          <div class="absolute top-10 left-10 w-32 h-32 border-2 border-emerald-500/30 rounded-full"></div>
          <div class="absolute bottom-10 right-10 w-48 h-48 border-2 border-green-500/30 rounded-full"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 border-2 border-emerald-400/20 rounded-full"></div>
        </div>
        <div class="text-center text-gray-300 relative z-10">
          <span class="text-6xl mb-6 block animate-float">🌱</span>
          <p class="text-2xl font-bold mb-3">Coming Soon</p>
          <p class="text-gray-400 mb-2">FLORA is currently in development</p>
          <p class="text-sm text-gray-500">Watch the GitHub repo for updates on this cozy botanical adventure</p>
        </div>
      </div>
    </div>
    
    <div class="glass-dark rounded-2xl p-6">
      <h2 class="text-2xl font-bold mb-4 text-emerald-400">About FLORA</h2>
      <div class="text-gray-300 leading-relaxed space-y-3">
        <p>
          Every run creates unique living botanical art through <strong>L-system fractals</strong>, 
          watercolor gradients, and seasonal palettes. A cozy experience where each garden tells its own story.
        </p>
        <p>
          Combining the meditative loop of gardening with roguelite progression, FLORA generates 
          procedural plants that grow and evolve based on mathematical beauty and natural patterns.
        </p>
      </div>
    </div>
  </div>
</Layout>
