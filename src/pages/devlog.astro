---
import Layout from '../layouts/Layout.astro';

interface DevlogEntry {
  date: string;
  dayNumber: number;
  events: {
    repo: string;
    type: 'issue' | 'pr' | 'deploy' | 'decision';
    title: string;
    url?: string;
  }[];
}

let devlogData: DevlogEntry[] = [];
try {
  const data = await import('../data/devlog.json');
  devlogData = data.default || [];
} catch (e) {
  // If no devlog.json exists yet, show placeholder
  devlogData = [{
    date: new Date().toISOString().split('T')[0],
    dayNumber: 1,
    events: [{
      repo: 'FirstFrameStudios',
      type: 'deploy',
      title: 'Devlog system initialized — awaiting first automated generation',
      url: undefined
    }]
  }];
}

const typeIcons: Record<string, string> = {
  issue: '✅',
  pr: '🔀',
  deploy: '🚀',
  decision: '📋'
};

const repoColors: Record<string, string> = {
  'Syntax-Sorcery': 'bg-purple-500/20 text-purple-300',
  'FirstFrameStudios': 'bg-blue-500/20 text-blue-300',
  'flora': 'bg-green-500/20 text-green-300',
  'ComeRosquillas': 'bg-yellow-500/20 text-yellow-300',
  'ffs-squad-monitor': 'bg-red-500/20 text-red-300',
};

const getRepoColor = (repo: string) => repoColors[repo] || 'bg-gray-500/20 text-gray-300';
---

<Layout title="Development Log — FirstFrame Studios" description="Daily automated development log tracking issues, PRs, deployments, and decisions across the constellation.">
  <!-- Hero -->
  <section class="bg-gradient-to-b from-gray-800 to-gray-900 py-12">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-primary to-purple-500">
        Development Log
      </h1>
      <p class="text-lg text-gray-300 max-w-3xl">
        Daily automated chronicle of progress across the constellation. Issues closed, PRs merged, deployments shipped, and decisions made — all tracked autonomously.
      </p>
      <p class="text-sm text-gray-400 mt-2">
        Last updated: {new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </div>
  </section>

  <!-- Devlog Entries -->
  <section class="container mx-auto px-4 py-12">
    <div class="space-y-12">
      {devlogData.length === 0 ? (
        <div class="bg-gray-800 rounded-lg p-8 text-center">
          <p class="text-gray-400">No devlog entries yet. The automated generation will populate this daily.</p>
        </div>
      ) : (
        devlogData.map((entry) => (
          <div class="bg-gray-800 rounded-lg p-6 shadow-lg border border-gray-700">
            <div class="flex items-center justify-between mb-4 border-b border-gray-700 pb-3">
              <h2 class="text-2xl font-bold text-primary">
                {new Date(entry.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
              </h2>
              <span class="text-sm bg-gray-700 px-3 py-1 rounded-full text-gray-300">
                Day {entry.dayNumber}
              </span>
            </div>
            
            {entry.events.length === 0 ? (
              <p class="text-gray-400 italic">No activity recorded for this day.</p>
            ) : (
              <ul class="space-y-3">
                {entry.events.map((event) => (
                  <li class="flex items-start gap-3 group">
                    <span class="text-2xl flex-shrink-0">{typeIcons[event.type]}</span>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class={`text-xs px-2 py-1 rounded font-medium ${getRepoColor(event.repo)}`}>
                          {event.repo}
                        </span>
                        {event.url ? (
                          <a 
                            href={event.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-gray-200 hover:text-primary transition-colors group-hover:underline"
                          >
                            {event.title}
                          </a>
                        ) : (
                          <span class="text-gray-200">{event.title}</span>
                        )}
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      )}
    </div>
  </section>

  <!-- Info Box -->
  <section class="container mx-auto px-4 pb-12">
    <div class="bg-gradient-to-br from-primary/10 to-purple-500/10 rounded-lg p-6 border border-primary/20">
      <h3 class="text-lg font-bold mb-2">How This Works</h3>
      <p class="text-sm text-gray-300">
        This devlog is generated automatically every day at 02:00 UTC by GitHub Actions. It aggregates closed issues, merged PRs, deployments, and Squad decisions from all constellation repositories. No human writes a single line — the team works 24/7, and the devlog captures it all.
      </p>
    </div>
  </section>
</Layout>
