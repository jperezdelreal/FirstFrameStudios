---

<BaseLayout title="Status">
  <!-- Hero Section (compact, with At-a-Glance stats integrated) -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#8b5cf6]/10 via-transparent to-[#06b6d4]/10"></div>
    <div class="absolute top-20 left-1/4 w-96 h-96 bg-[#8b5cf6]/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-1/4 w-96 h-96 bg-[#06b6d4]/5 rounded-full blur-3xl"></div>

    <div class="relative max-w-6xl mx-auto px-6 py-20 md:py-28 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#8b5cf6]/30 bg-[#8b5cf6]/10 text-sm text-[#a78bfa] mb-6">
        <span>Last updated: March 2026</span>
      </div>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-4 tracking-tight">
        🏗️ Inside the Studio
      </h1>
      <p class="text-lg md:text-xl text-[#9890b0] max-w-2xl mx-auto leading-relaxed mb-10">
        A living snapshot of how <span class="text-[#a78bfa] font-semibold">First Frame Studios</span> operates
      </p>

      <!-- At-a-Glance counters integrated into hero -->
      <div class="flex flex-wrap justify-center gap-8 md:gap-12">
        {heroStats.map((stat) => (
          <div class="flex flex-col items-center">
            <span class="text-2xl mb-1">{stat.icon}</span>
            <span class="text-3xl md:text-4xl font-bold text-white" data-count={stat.value}>0</span>
            <span class="text-xs text-[#9890b0] mt-1 uppercase tracking-wider">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ What Powers the Studio (THE STAR SECTION) ═══ -->
  <section class="max-w-6xl mx-auto px-6 py-24 fade-on-scroll">
    <div class="text-center mb-20">
      <p class="text-sm text-[#a78bfa] uppercase tracking-widest font-medium mb-3">Core Capabilities</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">What Powers the Studio</h2>
      <p class="text-lg text-[#9890b0] max-w-2xl mx-auto leading-relaxed">
        Capabilities forged through shipped games and running infrastructure.
      </p>
    </div>

    <div class="space-y-16">
      {capabilities.map((cap, idx) => (
        <>
          <div class="fade-on-scroll">
            <div class="flex items-center gap-4 mb-4">
              <span class="text-4xl">{cap.icon}</span>
              <h3 class="text-2xl md:text-3xl font-bold text-white">{cap.title}</h3>
            </div>
            <p class="text-[#9890b0] text-base leading-relaxed mb-6 max-w-2xl italic">{cap.oneLiner}</p>
            <div class="flex flex-wrap gap-3">
              {cap.skills.map((skill: { name: string; featured: boolean }) => (
                <span class={`capability-pill cursor-default border rounded-full font-medium ${cap.pillBg} ${skill.featured ? 'text-sm px-5 py-2.5' : 'text-xs px-4 py-2'}`}>
                  {skill.name}
                </span>
              ))}
            </div>
          </div>
          {idx < capabilities.length - 1 && <div class="category-separator"></div>}
        </>
      ))}
    </div>
  </section>

  <!-- ═══ The Team — Clickable Expandable Cards ═══ -->
  <section class="max-w-6xl mx-auto px-6 py-20 fade-on-scroll">
    <div class="text-center mb-14">
      <p class="text-sm text-[#06b6d4] uppercase tracking-widest font-medium mb-3">The Squad</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">The Team</h2>
      <p class="text-[#9890b0] max-w-xl mx-auto">One human founder and a squad of specialized AI agents. Click any card to learn more.</p>
    </div>

    <!-- Active agents -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mb-6">
      {activeAgents.map((agent) => (
        <details class="team-card rounded-xl border border-white/10 bg-white/[0.03] transition-all duration-300">
          <summary class="p-4 rounded-xl hover:bg-white/[0.06] hover:border-[#8b5cf6]/30 transition-all duration-300 text-center">
            <div class="text-2xl mb-2">{agent.emoji}</div>
            <div class="text-white font-semibold text-sm">{agent.name}</div>
            <div class="text-xs text-[#9890b0] mt-1">{agent.role}</div>
            <div class="expand-hint text-[10px] text-[#9890b0]/50 mt-2">▼</div>
          </summary>
          <div class="px-4 pb-4 border-t border-white/5 pt-3">
            <p class="text-xs text-[#a78bfa] font-semibold mb-2">{agent.emoji} {agent.name} — {agent.fullRole}</p>
            <div class="text-xs text-[#9890b0]/60 mb-2">━━━</div>
            <ul class="text-xs text-[#e2e0f0] space-y-1 mb-3">
              {agent.responsibilities.map((r: string) => (
                <li>• {r}</li>
              ))}
            </ul>
            <p class="text-[10px] text-[#9890b0]">Domains: {agent.domains}</p>
            <p class="text-[10px] text-[#9890b0]">Status: {agent.status}</p>
          </div>
        </details>
      ))}
    </div>

    <!-- Hibernated agents -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
      {hibernatedAgents.map((agent) => (
        <details class="team-card rounded-xl border border-white/5 bg-white/[0.01] opacity-50 transition-all duration-300">
          <summary class="p-4 rounded-xl hover:opacity-80 transition-all duration-300 text-center">
            <div class="text-2xl mb-2 relative inline-block">
              {agent.emoji}
              <span class="absolute -top-1 -right-3 text-xs">💤</span>
            </div>
            <div class="text-white/60 font-semibold text-sm">{agent.name}</div>
            <div class="text-xs text-[#9890b0]/60 mt-1">Hibernated</div>
            <div class="expand-hint text-[10px] text-[#9890b0]/30 mt-2">▼</div>
          </summary>
          <div class="px-4 pb-4 border-t border-white/5 pt-3">
            <p class="text-xs text-[#a78bfa]/60 font-semibold mb-2">{agent.emoji} {agent.name} — {agent.fullRole}</p>
            <div class="text-xs text-[#9890b0]/40 mb-2">━━━</div>
            <ul class="text-xs text-[#e2e0f0]/60 space-y-1 mb-3">
              {agent.responsibilities.map((r: string) => (
                <li>• {r}</li>
              ))}
            </ul>
            <p class="text-[10px] text-[#9890b0]/50">Domains: {agent.domains}</p>
            <p class="text-[10px] text-[#9890b0]/50">Status: {agent.status}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══ What's New — Expanded Timeline ═══ -->
  <section class="max-w-4xl mx-auto px-6 py-20 fade-on-scroll">
    <div class="text-center mb-16">
      <p class="text-sm text-[#06b6d4] uppercase tracking-widest font-medium mb-3">Studio Journal</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">What's New</h2>
      <p class="text-[#9890b0] max-w-xl mx-auto">The story so far — every milestone in the studio's journey.</p>
    </div>
    <div class="relative">
      <div class="absolute left-4 md:left-6 top-0 bottom-0 w-px bg-gradient-to-b from-[#8b5cf6]/60 via-[#06b6d4]/40 to-transparent"></div>
      <div class="space-y-10">
        {timeline.map((entry, i) => (
          <div class="relative pl-12 md:pl-16 fade-on-scroll">
            <div class={`absolute left-2.5 md:left-4.5 top-1.5 w-3 h-3 rounded-full border-2 ${i === 0 ? 'bg-[#8b5cf6] border-[#8b5cf6] shadow-[0_0_8px_rgba(139,92,246,0.5)]' : 'bg-[#0f0d1a] border-[#06b6d4]/60'}`}></div>
            <div class="text-xs text-[#a78bfa] font-medium mb-1">{entry.date}</div>
            <h4 class="text-white font-semibold text-base mb-1">{entry.title}</h4>
            <p class="text-[#9890b0] text-sm leading-relaxed italic">"{entry.detail}"</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ Games & Tools (secondary — pushed down) ═══ -->
  <section class="max-w-6xl mx-auto px-6 py-20 fade-on-scroll">
    <div class="text-center mb-12">
      <p class="text-sm text-[#a78bfa] uppercase tracking-widest font-medium mb-3">What We Ship</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Games &amp; Tools</h2>
      <p class="text-[#9890b0] max-w-xl mx-auto">What the studio is building right now.</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {games.map((game) => (
        <div class="group relative p-8 rounded-2xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-[#8b5cf6]/30 transition-all duration-300 flex flex-col">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[#8b5cf6]/5 via-transparent to-[#06b6d4]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
          <div class="relative flex-1">
            <div class="flex items-start justify-between mb-4">
              <span class="text-5xl">{game.emoji}</span>
              <span class={`text-xs font-medium px-3 py-1 rounded-full border ${game.statusBg} ${game.statusColor}`}>
                {game.status}
              </span>
            </div>
            <h3 class="text-white font-bold text-xl mb-1 group-hover:text-[#a78bfa] transition-colors">{game.title}</h3>
            <p class="text-xs text-[#a78bfa]/60 font-medium mb-3">{game.subtitle}</p>
            <p class="text-sm text-[#9890b0] mb-5 leading-relaxed">{game.description}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              {game.stack.map((tech: string) => (
                <span class="text-xs px-2.5 py-1 rounded-md bg-white/5 text-[#9890b0] border border-white/5">{tech}</span>
              ))}
            </div>
          </div>
          <div class="relative flex flex-wrap gap-3 mt-auto">
            {game.playUrl && (
              <a href={game.playUrl} target="_blank" rel="noopener"
                class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#8b5cf6] hover:bg-[#7c3aed] text-white rounded-lg text-sm font-medium transition-colors">
                Play Now →
              </a>
            )}
            <a href={game.sourceUrl} target="_blank" rel="noopener"
              class="inline-flex items-center gap-2 px-5 py-2.5 border border-white/20 hover:border-white/40 text-white rounded-lg text-sm font-medium transition-colors">
              Source →
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="max-w-4xl mx-auto px-6 py-20 text-center fade-on-scroll">
    <div class="p-10 rounded-2xl border border-[#8b5cf6]/20 bg-gradient-to-br from-[#8b5cf6]/5 to-transparent">
      <h2 class="text-3xl font-bold text-white mb-4">Built with Squad 🌌</h2>
      <p class="text-[#9890b0] max-w-lg mx-auto mb-6">
        15 AI agents, Star Wars universe casting, structured autonomy. One human founder + specialized agents = a studio that ships.
      </p>
      <a href="https://github.com/bradygaster/squad" target="_blank"
        class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-white/15 text-white rounded-lg font-medium transition-colors">
        Learn about Squad →
      </a>
    </div>
  </section>

  <!-- Client-side scripts for animations -->
  <script>
    // Fade-in on scroll via IntersectionObserver
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-on-scroll').forEach(el => observer.observe(el));

    // Animated counters for hero stats
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.count || '0');
          let current = 0;
          const increment = Math.ceil(target / 30);
          const timer = setInterval(() => {
            current = Math.min(current + increment, target);
            el.textContent = String(current);
            if (current >= target) clearInterval(timer);
          }, 40);
          counterObserver.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-count]').forEach(el => counterObserver.observe(el));
  </script>
</BaseLayout>
